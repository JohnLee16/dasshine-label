# Dasshine Label 环境配置

# 应用配置
APP_NAME=Dasshine Label
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# 安全配置（生产环境必须修改）
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 数据库配置
DATABASE_URL=postgresql://dasshine:dasshine123@localhost:5432/dasshine_label
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis配置
REDIS_URL=redis://localhost:6379/0

# CORS配置
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=.txt,.pdf,.jpg,.jpeg,.png,.json,.csv,.jsonl

# 自动标注配置
AUTO_LABEL_ENABLED=true
AUTO_LABEL_CONFIDENCE_THRESHOLD=0.8

# 任务分发配置
TASK_DISPATCH_BATCH_SIZE=100
TASK_DISPATCH_INTERVAL=60

# 质量控制配置
QUALITY_GOLDEN_RATIO=0.1
QUALITY_MIN_AGREEMENT=0.8
